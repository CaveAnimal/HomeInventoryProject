+            importError.textContent = json.vision_error;
+            importError.hidden = false;
+          }
+          for (const s of json.suggestions) addDetectionRow(s);
+          resultCard.scrollIntoView({ behavior: "smooth" });
+        } catch {
+          importing.hidden = true;
+          importError.textContent = "Import failed. Check the files and try again.";
+          importError.hidden = false;
+        }
+        importBtn.disabled = false;
+      });
+
+      confirmBtn.addEventListener("click", async () => {
+        const confirm = [];
+        const dismiss = [];
+        for (const [id, entry] of Object.entries(pending)) {
+          if (entry.checkbox.checked) {
+            confirm.push({
+              id: Number(id),
+              quantity: Math.max(1, Number(entry.qtyInput.value) || 1),
+              merge_ids: entry.mergeIds,
+            });
+          } else {
+            dismiss.push(Number(id), ...entry.mergeIds);
+          }
+        }
+        if (!confirm.length && !dismiss.length) return;
+        confirmBtn.disabled = true;
+        try {
+          const res = await fetch("/api/detections/confirm-batch", {
+            method: "POST",
+            headers: { "Content-Type": "application/json" },
+            body: JSON.stringify({ confirm, dismiss }),
+          });
+          if (!res.ok) throw new Error();
+          const json = await res.json();
+          for (const key of Object.keys(pending)) {
+            pending[key].row.remove();
+            delete pending[key];
+          }
+          confirmStatus.textContent = `Saved ${json.confirmed.length} item(s) to inventory` +
+            (json.dismissed_count ? `, dismissed ${json.dismissed_count}.` : ".");
+          confirmStatus.hidden = false;
+        } catch {
+          confirmStatus.textContent = "Could not save. Try again.";
+          confirmStatus.hidden = false;
+        }
+        confirmBtn.disabled = false;
+      });
+    </script>
+  </main>
+</body>
+</html>
